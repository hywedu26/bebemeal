rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, babyName, babyBirthday, mealsPerDay, sideDishesPerMeal
    //
    // Collection: inventory
    // Fields: uid, name, category, quantity, unit, addedAt
    //
    // Collection: meals
    // Fields: uid, date, mealIndex, recipeName, ingredients
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.email is string;
    }

    function isValidInventory(data) {
      return data.uid is string && data.name is string && data.category in ['carbohydrate', 'protein', 'vegetable', 'fruit', 'raw'] && data.quantity is number;
    }

    function isValidMeal(data) {
      return data.uid is string && data.date is string && data.mealIndex is int && data.recipeName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /inventory/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidInventory(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidInventory(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /meals/{mealId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidMeal(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidMeal(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /user_tokens/{userId} {
      // Only the user can read their own tokens (though usually only server does this)
      allow read: if isOwner(userId);
      // Only the user can write their own tokens (though usually only server does this)
      allow write: if isOwner(userId);
    }
  }
}
